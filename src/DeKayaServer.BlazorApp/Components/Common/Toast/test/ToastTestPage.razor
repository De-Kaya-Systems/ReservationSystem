@page "/toast-test"

@using DeKayaServer.BlazorApp.Services
@rendermode InteractiveServer
@inject ToastService Toasts

<h3>Toast Test Page</h3>

<div style="max-width: 520px; display: grid; gap: 12px;">

    <div style="display:flex; gap:10px; flex-wrap:wrap;">
        <button class="btn btn-success" @onclick="() => Toasts.ShowSuccess()">Success (default)</button>
        <button class="btn btn-danger" @onclick="() => Toasts.ShowError()">Error (default)</button>
        <button class="btn btn-warning" @onclick="() => Toasts.ShowWarning()">Warning (default)</button>
        <button class="btn btn-info" @onclick="() => Toasts.ShowInfo()">Info (default)</button>
    </div>

    <hr />

    <label style="font-weight:600;">Custom message</label>
    <input class="form-control"
           placeholder="Type a message..."
           @bind="CustomMessage" />

    <div style="display:flex; gap:10px; flex-wrap:wrap;">
        <button class="btn btn-success" @onclick="ShowCustomSuccess">Success (custom)</button>
        <button class="btn btn-danger" @onclick="ShowCustomError">Error (custom)</button>
        <button class="btn btn-warning" @onclick="ShowCustomWarning">Warning (custom)</button>
        <button class="btn btn-info" @onclick="ShowCustomInfo">Info (custom)</button>
    </div>

    <hr />

    <div style="display:flex; gap:10px; flex-wrap:wrap;">
        <button class="btn btn-secondary" @onclick="SpamToasts">Spam x5</button>
        <button class="btn btn-secondary" @onclick="ShowShortToast">Short (1.2s)</button>
        <button class="btn btn-secondary" @onclick="ShowLongToast">Long (10s)</button>
    </div>

    <hr />

    <div style="display:flex; gap:10px; flex-wrap:wrap; align-items:center;">
        <button class="btn btn-dark" @onclick="ShowManualHideToast">Show toast (save id)</button>
        <button class="btn btn-outline-dark" @onclick="HideSavedToast" disabled="@string.IsNullOrWhiteSpace(SavedToastId)">
            Hide saved toast
        </button>
    </div>

    @if (!string.IsNullOrWhiteSpace(SavedToastId))
    {
        <small><strong>Saved toast id:</strong> @SavedToastId</small>
    }

</div>

@code {
    private string CustomMessage { get; set; } = "Hello from ToastTestPage 👋";
    private string? SavedToastId;

    private void ShowCustomSuccess() => Toasts.ShowSuccess(CustomMessage);
    private void ShowCustomError() => Toasts.ShowError(CustomMessage);
    private void ShowCustomWarning() => Toasts.ShowWarning(CustomMessage);
    private void ShowCustomInfo() => Toasts.ShowInfo(CustomMessage);

    private void SpamToasts()
    {
        Toasts.ShowInfo("Toast #1");
        Toasts.ShowSuccess("Toast #2");
        Toasts.ShowWarning("Toast #3");
        Toasts.ShowError("Toast #4");
        Toasts.ShowSuccess("Toast #5");
    }

    private void ShowShortToast()
        => Toasts.ShowToast(new ToastInput("Short", "This one closes quickly (1.2s).", ToastTypeEnum.Info, 1200));

    private void ShowLongToast()
        => Toasts.ShowToast(new ToastInput("Long", "This one stays for 10 seconds.", ToastTypeEnum.Warning, 10_000));

    private void ShowManualHideToast()
    {
        var toast = new ToastInput("Manual", "Click 'Hide saved toast' to close me.", ToastTypeEnum.Success, 20_000);
        SavedToastId = toast.Id;
        Toasts.ShowToast(toast);
    }

    private void HideSavedToast()
    {
        if (!string.IsNullOrWhiteSpace(SavedToastId))
        {
            Toasts.HideToast(SavedToastId);
            SavedToastId = null;
        }
    }
}
