@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Routing

@inject AuthenticationStateProvider AuthStateProvider

@if (checking)
{
    @Authorizing
}
else if (allowAnonymous || isAuthenticated)
{
    <RouteView RouteData="@RouteData" DefaultLayout="@DefaultLayout" />
}
else
{
    @NotAuthorized
}

@code {
    [Parameter, EditorRequired] public RouteData RouteData { get; set; } = default!;
    [Parameter] public Type? DefaultLayout { get; set; }

    [Parameter] public RenderFragment? NotAuthorized { get; set; }
    [Parameter] public RenderFragment? Authorizing { get; set; }

    private bool checking = true;
    private bool isAuthenticated;
    private bool allowAnonymous;

    protected override async Task OnParametersSetAsync()
    {
        checking = true;

        var pageType = RouteData.PageType;

        allowAnonymous = Attribute.IsDefined(pageType, typeof(AllowAnonymousAttribute), inherit: true);

        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        isAuthenticated = state.User?.Identity?.IsAuthenticated == true;

        checking = false;
    }
}
