@using DeKayaServer.BlazorApp.Components.Common.Dialog
@using DeKayaServer.BlazorApp.Models
@using System.ComponentModel.DataAnnotations
@inject IRoleService roleService
@inject IApiResultPresenter apiResultPresenter

<Dialog
    @ref="dialog"
    Title="Rol güncelleme işlemi">
    <ChildContent>
        <EditForm Model="@model" OnValidSubmit="HandleValidSubmitAsync">
            <div class="mb-4">
                <div class="form-floating">
                    <InputText @bind-Value="model.Name"
                               class="form-control"
                               placeholder="Rol adını girin" />
                    <label>Rol Adı</label>
                </div>
            </div>

            <div class="mb-4">
                <div class="p-3 bg-light rounded-3 border border-light">
                    <div class="form-check form-switch d-flex align-items-center">
                        <InputCheckbox class="form-check-input me-3 fs-5"
                                       @bind-Value="model.IsActive"
                                       role="switch"
                                       style="cursor: pointer;" />
                        <label class="form-check-label fw-semibold" style="cursor: pointer;">
                            Rol aktif mi?
                        </label>
                    </div>
                </div>
            </div>

            <div class="d-flex gap-3 justify-content-end mt-4 pt-3 border-top">
                <button type="button"
                        class="btn btn-outline-secondary px-4 py-2 fw-semibold"
                        @onclick="HideAsync"
                        disabled="@isSubmit">
                    İptal
                </button>
                <button type="submit"
                        class="btn btn-primary px-4 py-2 fw-semibold shadow-sm"
                        disabled="@isSubmit">
                    Güncelle
                </button>
            </div>
        </EditForm>
    </ChildContent>
</Dialog>



@code {
    private Dialog? dialog;
    private bool isSubmit;

    [Parameter] public string? RoleId { get; set; }
    [Parameter] public string? RoleName { get; set; }
    [Parameter] public bool RoleIsActive { get; set; }
    [Parameter] public EventCallback RoleUpdated { get; set; }

    private UpdateRoleViewModel model = new();

    protected override void OnParametersSet()
    {
        model.Name = RoleName ?? string.Empty;
        model.IsActive = RoleIsActive;
    }

    public async Task ShowAsync()
    {
        if (dialog is not null)
        {
            await dialog.ShowAsync();
        }
    }

    public async Task HideAsync()
    {
        if (dialog is not null)
        {
            await dialog.HideAsync();
        }
    }

    private async Task HandleValidSubmitAsync()
    {
        if ( string.IsNullOrEmpty( RoleId ) || !Guid.TryParse( RoleId, out var roleGuid ) )
        {
            return;
        }
        try
        {
            isSubmit = true;
            var result = await roleService.UpdateAsync( roleGuid, model.Name, model.IsActive);
            apiResultPresenter.Present( result, new ApiPresentationOptions { ShowSuccess = true } );

            if(!result.IsSuccessful)
            {
                return;
            }

            if ( RoleUpdated.HasDelegate )
            {
                await RoleUpdated.InvokeAsync();
            }
        }
        finally
        {
            isSubmit = false;
            await HideAsync();
        }
    }


    public sealed class UpdateRoleViewModel
    {
        [Required( ErrorMessage = "Rol adı gereklidir." )]
        public string Name { get; set; } = null!;

        public bool IsActive { get; set; }
    }

}
