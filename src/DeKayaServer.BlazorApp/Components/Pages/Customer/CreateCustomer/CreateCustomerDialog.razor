@using DeKayaServer.BlazorApp.Components.Common.Dialog
@using System.ComponentModel.DataAnnotations
@using DeKayaServer.BlazorApp.Models
@using System.Net.Http.Json
@using System.Text.Json.Serialization
@using DeKayaServer.Contracts.Customers
@using DeKayaServer.Contracts.Dto
@inject ICustomerService customerService
@inject IApiResultPresenter apiResultPresenter
@inject ToastService toastService
@inject HttpClient Http
@rendermode InteractiveServer

<Dialog @ref="dialog"
        Title="Müşteri Ekle">
    <ChildContent>
        <EditForm EditContext="@editContext"
                  OnValidSubmit="HandleValidSubmit"
                  OnInvalidSubmit="HandleInvalidSubmit">
            <DataAnnotationsValidator />

            <div class="row g-3 mb-3">
                <div class="col-12 col-md-6">
                    <div class="form-floating">
                        <InputText @bind-Value="model.FirstName"
                                   class="form-control"
                                   placeholder="Ad" />
                        <label>Müşteri Adı</label>
                    </div>
                    <ValidationMessage For="@(() => model.FirstName)" class="fw-light fs-6 my-1 py-2 alert alert-danger" />
                </div>

                <div class="col-12 col-md-6">
                    <div class="form-floating">
                        <InputText @bind-Value="model.LastName"
                                   class="form-control"
                                   placeholder="Soyad" />
                        <label>Müşteri Soyadı</label>
                    </div>
                    <ValidationMessage For="@(() => model.LastName)" class="fw-light fs-6 my-1 py-2 alert alert-danger" />
                </div>
            </div>

            <div class="row g-3 mb-3">
                <div class="col-12 col-md-6">
                    <div class="form-floating">
                        <InputText @bind-Value="model.PhoneNumber"
                                   class="form-control"
                                   placeholder="Telefon" />
                        <label>Telefon</label>
                    </div>
                    <ValidationMessage For="@(() => model.PhoneNumber)" class="fw-light fs-6 my-1 py-2 alert alert-danger" />
                </div>

                <div class="col-12 col-md-6">
                    <div class="form-floating">
                        <InputText @bind-Value="model.PhoneNumber2"
                                   class="form-control"
                                   placeholder="Alternatif telefon numarası(zorunlu değil)" />
                        <label>Alternatif telefon numarası</label>
                    </div>
                    <ValidationMessage For="@(() => model.PhoneNumber2)" class="fw-light fs-6 my-1 py-2 alert alert-danger" />
                </div>
            </div>

            <div class="row g-3 mb-3">
                <div class="col-12 col-md-6">
                    <div class="form-floating">
                        <InputText @bind-Value="model.Email"
                                   class="form-control"
                                   placeholder="E-posta" />
                        <label>E-posta</label>
                    </div>
                    <ValidationMessage For="@(() => model.Email)" class="fw-light fs-6 my-1 py-2 alert alert-danger" />
                </div>

                <div class="col-12 col-md-6">
                    <div class="form-floating">
                        <InputSelect class="form-select"
                                     @bind-Value="model.City"
                                     @bind-Value:after="OnCityChanged">
                            <option value="">Şehir seçiniz</option>
                            @foreach ( var city in cities )
                            {
                                <option value="@city">@city</option>
                            }
                        </InputSelect>
                        <label>Şehir</label>
                    </div>
                    <ValidationMessage For="@(() => model.City)" class="fw-light fs-6 my-1 py-2 alert alert-danger" />
                </div>
            </div>

            <div class="mb-3">
                <div class="form-floating">
                    <InputSelect class="form-select"
                                 @bind-Value="model.District"
                                 disabled="@(!districts.Any())">
                        <option value="" disabled selected>İlçe seçiniz</option>
                        @foreach ( var district in districts )
                        {
                            <option value="@district">@district</option>
                        }
                    </InputSelect>
                    <label>İlçe</label>
                </div>
                <ValidationMessage For="@(() => model.District)" class="fw-light fs-6 my-2 py-2 alert alert-danger" />
            </div>

            <div class="mb-4">
                <div class="form-floating">
                    <InputText @bind-Value="model.FullAddress"
                               class="form-control"
                               placeholder="Adres" />
                    <label>Adres</label>
                </div>
                <ValidationMessage For="@(() => model.FullAddress)" class="fw-light fs-6 my-2 py-2 alert alert-danger" />
            </div>

            <div class="d-flex gap-3 justify-content-end mt-4 pt-3 border-top">
                <button type="button"
                        class="btn btn-outline-secondary px-4 py-2 fw-semibold"
                        @onclick="HideAsync"
                        disabled="@isSubmit">
                    İptal
                </button>

                <button type="submit"
                        class="btn btn-primary px-4 py-2 fw-semibold shadow-sm"
                        disabled="@SubmitDisabled">
                    Kaydet
                </button>
            </div>
        </EditForm>
    </ChildContent>
</Dialog>

@code {
    private Dialog? dialog;
    private bool isSubmit;

    private CreateCustomerViewModel model = new();

    private EditContext editContext = default!;
    private bool submitAttempted;

    private List<CityDistrictJson> cityDistrictSource = [];
    private List<string> cities = [];
    private List<string> districts = [];

    private bool SubmitDisabled =>
        isSubmit || ( submitAttempted && editContext.GetValidationMessages().Any() );

    [Parameter] public EventCallback CustomerAdded { get; set; }

    protected override async Task OnInitializedAsync()
    {
        InitForm();
        await LoadCityDistrictDataAsync();
        await base.OnInitializedAsync();
    }

    public async Task ShowAsync()
    {
        if ( dialog is null )
        {
            return;
        }
        submitAttempted = false;
        InitForm();

        RefreshDistricts();

        await InvokeAsync( StateHasChanged );
        await dialog.ShowAsync();
    }

    public async Task HideAsync()
    {
        if ( dialog is null )
        {
            return;
        }

        submitAttempted = false;
        InitForm();
        RefreshDistricts();

        await InvokeAsync( StateHasChanged );
        await dialog.HideAsync();
    }

    private void InitForm()
    {
        model = new();
        editContext = new EditContext( model );
        editContext.OnValidationStateChanged += OnValidationStateChanged;
    }

    private void RefreshDistricts()
    {
        if ( string.IsNullOrWhiteSpace( model.City ) )
        {
            districts = [];
            return;
        }

        var city = cityDistrictSource.FirstOrDefault( x =>
            string.Equals( x.CityName, model.City, StringComparison.OrdinalIgnoreCase ) );

        districts = city?.Districts?
            .Select( d => d.DistrictName )
            .Where( n => !string.IsNullOrWhiteSpace( n ) )
            .Distinct( StringComparer.OrdinalIgnoreCase )
            .OrderBy( n => n )
            .ToList() ?? [];
    }

    private async Task LoadCityDistrictDataAsync()
    {
        cityDistrictSource = await Http.GetFromJsonAsync<List<CityDistrictJson>>( "/data/ege-il-ilce.json" ) ?? [];

        cities = cityDistrictSource
            .Select( x => x.CityName )
            .Where( n => !string.IsNullOrWhiteSpace( n ) )
            .Distinct( StringComparer.OrdinalIgnoreCase )
            .OrderBy( n => n )
            .ToList();

        RefreshDistricts();
    }

    private void OnCityChanged()
    {
        model.District = string.Empty;
        RefreshDistricts();
    }

    private void OnValidationStateChanged( object? sender, ValidationStateChangedEventArgs e )
        => _ = InvokeAsync( StateHasChanged );

    private void HandleInvalidSubmit()
    {
        submitAttempted = true;
    }

    private async Task HandleValidSubmit()
    {
        try
        {
            isSubmit = true;

            var request = new CreateCustomerRequest
            {
                FirstName = model.FirstName,
                LastName = model.LastName,
                Address = new Address
                {
                    City = model.City,
                    District = model.District,
                    FullAddress = model.FullAddress
                },
                Contact = new Contact
                {
                    PhoneNumber = model.PhoneNumber,
                    PhoneNumber2 = model.PhoneNumber2,
                    Email = model.Email
                },
                IsActive = true
            };

            var result = await customerService.CreateAsync( request );

            apiResultPresenter.Present( result, new ApiPresentationOptions { ShowSuccess = true } );

            if ( !result.IsSuccessful )
            {
                return;
            }

            if ( CustomerAdded.HasDelegate )
            {
                await CustomerAdded.InvokeAsync();
            }
        }
        finally
        {
            isSubmit = false;
            submitAttempted = false;
            InitForm();
            RefreshDistricts();
            await HideAsync();
        }
    }

    public sealed class CityDistrictJson
    {
        [JsonPropertyName( "il_adi" )]
        public string CityName { get; set; } = string.Empty;

        [JsonPropertyName( "ilceler" )]
        public List<DistrictJson> Districts { get; set; } = [];
    }

    public sealed class DistrictJson
    {
        [JsonPropertyName( "ilce_adi" )]
        public string DistrictName { get; set; } = string.Empty;
    }

    public sealed class CreateCustomerViewModel
    {
        [Required( ErrorMessage = "Müşteri adı giriniz!" )]
        public string FirstName { get; set; } = string.Empty;

        [Required( ErrorMessage = "Müşteri Soyadı giriniz!" )]
        public string LastName { get; set; } = string.Empty;

        [Required( ErrorMessage = "Şehir giriniz!" )]
        public string City { get; set; } = string.Empty;

        [Required( ErrorMessage = "İlçe giriniz!" )]
        public string District { get; set; } = string.Empty;

        [Required( ErrorMessage = "Tam adres giriniz!" )]
        public string FullAddress { get; set; } = string.Empty;

        [Required( ErrorMessage = "Telefon numarası giriniz!" )]
        [RegularExpression( @"^\+905\d{9}$", ErrorMessage = "Telefon formatı hatalı. Örn: +905XXXXXXXXX" )]
        public string PhoneNumber { get; set; } = string.Empty;

        [RegularExpression( @"^\+905\d{9}$", ErrorMessage = "Telefon formatı hatalı. Örn: +905XXXXXXXXX" )]
        public string? PhoneNumber2 { get; set; }

        [EmailAddress( ErrorMessage = "Geçerli bir e-posta adresi giriniz!" )]
        public string? Email { get; set; }
    }
}