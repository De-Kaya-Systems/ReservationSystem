@using DeKayaServer.BlazorApp.Components.Common.Dialog
@using DeKayaServer.BlazorApp.Models
@inject ICustomerService customerService
@inject IApiResultPresenter apiResultPresenter

<Dialog @ref="dialog"
        Title="Müşteriyi sil">
    <ChildContent>
        <div class="py-3">
            <p>Bu müşteriyi ( <span class="fw-bolder">@FullName</span> ) silmek istediğinize emin misiniz?</p>
        </div>
        <div class="d-flex gap-3 justify-content-end mt-4 pt-3 border-top">
            <button type="button"
                    class="btn btn-outline-secondary px-4 py-2 fw-semibold"
                    @onclick="HideAsync"
                    disabled="@isSubmit">
                İptal
            </button>
            <button type="button"
                    class="btn btn-danger px-4 py-2 fw-semibold shadow-sm"
                    @onclick="HandleDeleteAsync"
                    disabled="@isSubmit">
                Sil
            </button>
        </div>
    </ChildContent>
</Dialog>

@code {
    private Dialog? dialog;
    private bool isSubmit;

    [Parameter] public Guid? CustomerId { get; set; }
    [Parameter] public string? FullName { get; set; }
    [Parameter] public EventCallback CustomerDeleted { get; set; }

    public async Task ShowAsync()
    {
        if ( dialog is not null )
            await dialog.ShowAsync();
    }

    public async Task HideAsync()
    {
        if ( dialog is not null )
            await dialog.HideAsync();
    }

    private async Task HandleDeleteAsync()
    {
        if ( CustomerId is null )
            return;

        try
        {
            isSubmit = true;
            var result = await customerService.DeleteAsync( CustomerId.Value );

            apiResultPresenter.Present( result, new ApiPresentationOptions { ShowSuccess = true } );

            if ( !result.IsSuccessful )
                return;

            if ( CustomerDeleted.HasDelegate )
                await CustomerDeleted.InvokeAsync();
        }
        finally
        {
            isSubmit = false;
            await HideAsync();
        }
    }
}