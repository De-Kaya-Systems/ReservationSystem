@using DeKayaServer.BlazorApp.Components.Common.Dialog
@using DeKayaServer.BlazorApp.Models
@using System.ComponentModel.DataAnnotations
@inject IUserService userService
@inject IRoleService roleService
@inject IApiResultPresenter apiResultPresenter

<Dialog @ref="dialog"
        Title="Kullanıcı güncelle">
    <ChildContent>
        @if ( isLoading )
        {
            <IsLoading Message="Kullanıcı bilgileri yükleniyor, lütfen bekleyin." />
        }
        else
        {
            <EditForm Model="@model" OnValidSubmit="HandleValidSubmitAsync">
            <DataAnnotationsValidator />

            <div class="row g-3 mb-3">
                <div class="col-12 col-md-6">
                    <div class="form-floating">
                        <InputText @bind-Value="model.FirstName"
                                       class="form-control"
                                   placeholder="Ad" />
                        <label>Ad</label>
                    </div>
                    <ValidationMessage For="@(() => model.FirstName)" class="fw-light fs-6 my-1 py-2 alert alert-danger" />
                </div>

                <div class="col-12 col-md-6">
                    <div class="form-floating">
                        <InputText @bind-Value="model.LastName"
                                       class="form-control"
                                   placeholder="Soyad" />
                        <label>Soyad</label>
                    </div>
                    <ValidationMessage For="@(() => model.LastName)" class="fw-light fs-6 my-1 py-2 alert alert-danger" />
                </div>
            </div>

            <div class="row g-3 mb-3">
                <div class="col-12 col-md-6">
                    <div class="form-floating">
                        <InputText @bind-Value="model.Email"
                                   class="form-control"
                                   placeholder="E-posta" />
                        <label>E-posta</label>
                    </div>
                    <ValidationMessage For="@(() => model.Email)" class="fw-light fs-6 my-1 py-2 alert alert-danger" />
                </div>

                <div class="col-12 col-md-6">
                    <div class="form-floating">
                        <InputText @bind-Value="model.UserName"
                                   class="form-control"
                                   placeholder="Kullanıcı adı" />
                        <label>Kullanıcı adı</label>
                    </div>
                    <ValidationMessage For="@(() => model.UserName)" class="fw-light fs-6 my-1 py-2 alert alert-danger" />
                </div>
            </div>

            <div class="mb-4">
                <div class="form-floating">
                    <InputSelect 
                        TValue="Guid?" 
                        @bind-Value="model.RoleId"
                        class="form-select">
                            <option value="">Rol seçin</option>
                            @foreach ( var role in roles )
                            {
                                <option value="@role.Id">@role.Name</option>
                            }
                    </InputSelect>
                    <label>Rol</label>
                </div>
                <ValidationMessage For="@(() => model.RoleId)" class="fw-light fs-6 my-2 py-2 alert alert-danger" />
            </div>

            <div class="d-flex gap-3 justify-content-end mt-4 pt-3 border-top">
                <button type="button"
                        class="btn btn-outline-secondary px-4 py-2 fw-semibold"
                        @onclick="HideAsync"
                        disabled="@isSubmit">
                    İptal
                </button>

                <button type="submit"
                        class="btn btn-primary px-4 py-2 fw-semibold shadow-sm"
                        disabled="@isSubmit">
                    Güncelle
                </button>
            </div>
        </EditForm>
        }
    </ChildContent>
</Dialog>

@code {
    private Dialog? dialog;
    private bool isSubmit;
    private bool isLoading;

    private List<RoleOption> roles = [];
    private UpdateUserViewModel model = new();

    [Parameter] public Guid? UserId { get; set; }
    [Parameter] public EventCallback UserUpdated { get; set; }

    public async Task ShowAsync()
    {
        if ( dialog is null || UserId is null )
            return;

        isLoading = true;
        await InvokeAsync( StateHasChanged );

        await LoadRolesAsync();
        await LoadUserAsync( UserId.Value );

        isLoading = false;
        await InvokeAsync( StateHasChanged );
        await dialog.ShowAsync();
    }

    public async Task HideAsync()
    {
        if ( dialog is null )
        {
            return;
        }
        await dialog.HideAsync();
    }

    private async Task LoadUserAsync( Guid id )
    {
        var res = await userService.GetByIdAsync( id );
        if ( !res.IsSuccessful || res.Data is null )
        {
            model = new();
            return;
        }

        model = new UpdateUserViewModel
        {
            FirstName = res.Data.FirstName,
            LastName = res.Data.LastName,
            Email = res.Data.Email,
            UserName = res.Data.UserName,
            RoleId = res.Data.RoleId
        };
    }
    
    private async Task LoadRolesAsync()
    {
        var res = await roleService.GetAllAsync();
        if ( !res.IsSuccessful || res.Data is null )
        {
            roles = [];
            return;
        }

        roles = res.Data
            .Select( r => new RoleOption( r.Id, r.Name ) )
            .OrderBy( r => r.Name )
            .ToList();

        await InvokeAsync( StateHasChanged );
    }


    private async Task HandleValidSubmitAsync()
    {
        if ( UserId is null )
        {
            return;
        }

        try
        {
            isSubmit = true;

            var result = await userService.UpdateAsync(
                UserId.Value,
                model.FirstName,
                model.LastName,
                model.Email,
                model.UserName,
                model.RoleId!.Value );

            apiResultPresenter.Present( result, new ApiPresentationOptions { ShowSuccess = true } );

            if ( !result.IsSuccessful )
            {
                return;
            }

            if ( UserUpdated.HasDelegate )
            {
                await UserUpdated.InvokeAsync();
            }
        }
        finally
        {
            isSubmit = false;
            await HideAsync();
        }
    }

    public sealed class UpdateUserViewModel
    {
        [Required( ErrorMessage = "İsim giriniz!" )]
        public string FirstName { get; set; } = string.Empty;

        [Required( ErrorMessage = "Soyisim giriniz!" )]
        public string LastName { get; set; } = string.Empty;

        [Required( ErrorMessage = "E-posta giriniz!" )]
        [EmailAddress( ErrorMessage = "Geçerli bir e-posta adresi giriniz!" )]
        public string Email { get; set; } = string.Empty;

        [Required( ErrorMessage = "Kullanıcı adı giriniz!" )]
        public string UserName { get; set; } = string.Empty;

        [Required( ErrorMessage = "Rol seçiniz!" )]
        public Guid? RoleId { get; set; }
    }

    private sealed record RoleOption( Guid Id, string Name );
}
