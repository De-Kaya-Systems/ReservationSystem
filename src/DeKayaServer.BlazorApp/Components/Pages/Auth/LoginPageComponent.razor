@page "/login"
@layout LoginLayout

@using DeKayaServer.BlazorApp.Constans
@using DeKayaServer.BlazorApp.Interfaces
@using DeKayaServer.BlazorApp.Services
@using DeKayaServer.BlazorApp.ViewModels
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@inject IAuthService AuthService;
@inject NavigationManager NavigationManager;
@inject AuthenticationStateProvider AuthStateProvider;
@attribute [AllowAnonymous]

<PageTitle>De-Kaya Systems | Login</PageTitle>

<div class="login-part">
    <div class="admin-login-wrapper">
        <div class="admin-login-container">
            <div class="admin-login-form">
                <div class="login-header">
                    <div class="admin-brand">
                        <img src="/images/dekaya.png" alt="De-Kaya Logo" />
                        <h1>De-Kaya Systems</h1>
                    </div>
                </div>

                <EditForm class="login-form"
                          Model="@loginViewModel"
                          OnValidSubmit="@HandleLoginAsync">
                    <DataAnnotationsValidator />

                    <div class="form-group">
                        <label for="adminEmail" class="form-label">E-posta Adresi veya Kullanici Adi</label>
                        <div class="input-group">
                            <span class="input-group-text">
                                <i class="bi bi-person"></i>
                            </span>
                            <InputText @bind-Value="loginViewModel.EmailOrUserName"
                                       class="form-control"
                                       id="adminEmail"
                                       placeholder="mail@de-kaya.com"
                                       autocomplete="username"
                                       disabled="@isSubmitting" />
                        </div>
                        <ValidationMessage For="@(() => loginViewModel.EmailOrUserName)" class="text-danger small pt-1" />
                    </div>

                    <div class="form-group">
                        <label for="adminPassword" class="form-label">Sifre</label>
                        <div class="input-group">
                            <span class="input-group-text">
                                <i class="bi bi-lock"></i>
                            </span>
                            <InputText @bind-Value="loginViewModel.Password"
                                       type="@(showPassword ? "text" : "password")"
                                       class="form-control"
                                       id="adminPassword"
                                       placeholder="Sifrenizi girin"
                                       autocomplete="current-password"
                                       disabled="@isSubmitting" />
                            <button type="button"
                                    class="input-group-text password-toggle"
                                    @onclick="TogglePasswordVisibility"
                                    disabled="@isSubmitting">
                                <i class="bi @(showPassword ? "bi-eye-slash" : "bi-eye")"></i>
                            </button>
                        </div>
                        <ValidationMessage For="@(() => loginViewModel.Password)" class="text-danger small pt-1" />
                    </div>

                    <div class="login-options">
                        <div class="form-check">
                            <InputCheckbox @bind-Value="rememberMe" class="form-check-input" id="rememberMe" disabled="@isSubmitting" />
                            <label class="form-check-label" for="rememberMe">
                                Beni hatirla
                            </label>
                        </div>
                        <a href="#" class="forgot-password" data-bs-toggle="modal"
                           data-bs-target="#forgotPasswordModal">
                            Sifremi unuttum
                        </a>
                    </div>

                    <button type="submit" class="btn btn-admin-primary w-100" disabled="@isSubmitting">
                        @if (isSubmitting)
                        {
                            <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                            <span>Giris yapiliyor...</span>
                        }
                        else
                        {
                            <i class="bi bi-shield-lock me-2"></i>
                            <span>Personel Girisi</span>
                        }
                    </button>
                </EditForm>

                <div class="login-footer">
                    <p class="copyright">© @DateTime.Now.Year De-Kaya Sogutma Sistemleri. Tüm haklari saklidir.</p>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [SupplyParameterFromQuery(Name = "returnUrl")]
    public string? ReturnUrl { get; set; }

    private LoginViewModel loginViewModel = new();
    private bool isSubmitting;
    private bool showPassword;
    private bool rememberMe;

    private async Task HandleLoginAsync()
    {
        if (isSubmitting)
            return;

        isSubmitting = true;
        StateHasChanged();

        try
        {
            await AuthService.LoginAsync(
                new(loginViewModel.EmailOrUserName, loginViewModel.Password),
                onSuccess: async (token) =>
                {
                    if (AuthStateProvider is TokenAuthenticationStateProvider tokenProvider
                        && !string.IsNullOrWhiteSpace(token))
                    {
                        await tokenProvider.MarkUserAsAuthenticatedAsync(token);
                    }

                    var targetUrl = string.IsNullOrWhiteSpace(ReturnUrl)
                        ? EndpointConstans.Dashboard
                        : "/" + ReturnUrl.TrimStart('/');

                    NavigationManager.NavigateTo(targetUrl);
                },
                onError: (result) =>
                {
                }
            );
        }
        finally
        {
            isSubmitting = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void TogglePasswordVisibility() => showPassword = !showPassword;
}
