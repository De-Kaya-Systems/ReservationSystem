@layout LoginLayout

@page "/login"

<div class="login-part">
    <!-- Admin Login -->
    <div class="admin-login-wrapper">
        <div class="admin-login-container">
            <!-- Left Side - Login Form -->
            <div class="admin-login-form">
                <div class="login-header">
                    <div class="admin-brand">
                        <img src="/images/dekaya.png" alt="De-Kaya Logo" />
                        <h1>De-Kaya Systems</h1>
                    </div>
                </div>

                <form class="login-form">
                    <!-- Email Input -->
                    <div class="form-group">
                        <label for="adminEmail" class="form-label">E-posta Adresi</label>
                        <div class="input-group">
                            <span class="input-group-text">
                                <i class="bi bi-person"></i>
                            </span>
                            <input type="email" class="form-control" id="adminEmail" placeholder="mail@de-kaya.com" required>
                        </div>
                    </div>

                    <!-- Password Input -->
                    <div class="form-group">
                        <label for="adminPassword" class="form-label">Şifre</label>
                        <div class="input-group">
                            <span class="input-group-text">
                                <i class="bi bi-lock"></i>
                            </span>
                            <input type="password" class="form-control" id="adminPassword" placeholder="Şifrenizi girin"
                                   required>
                            <button type="button" class="input-group-text password-toggle" data-target="adminPassword">
                                <i class="bi bi-eye"></i>
                            </button>
                        </div>
                    </div>

                    <!-- Login Options -->
                    <div class="login-options">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="rememberMe">
                            <label class="form-check-label" for="rememberMe">
                                Beni hatırla
                            </label>
                        </div>
                        <a href="#" class="forgot-password" data-bs-toggle="modal"
                           data-bs-target="#forgotPasswordModal">
                            Şifremi unuttum
                        </a>
                    </div>

                    <!-- Login Button -->
                    <button type="submit" class="btn btn-admin-primary w-100">
                        <i class="bi bi-shield-lock me-2"></i>
                        Personel Girişi
                    </button>

                    <!-- Two Factor -->
                    <div class="two-factor-section d-none">
                        <div class="two-factor-header">
                            <i class="bi bi-shield-check text-success"></i>
                            <h6>İki Faktörlü Doğrulama</h6>
                            <p>Telefonunuza gönderilen 6 haneli kodu girin</p>
                        </div>
                        <div class="verification-code">
                            <input type="text" class="code-input" maxlength="1">
                            <input type="text" class="code-input" maxlength="1">
                            <input type="text" class="code-input" maxlength="1">
                            <input type="text" class="code-input" maxlength="1">
                            <input type="text" class="code-input" maxlength="1">
                            <input type="text" class="code-input" maxlength="1">
                        </div>
                        <div class="verification-actions">
                            <button type="button" class="btn btn-outline-secondary">
                                <i class="bi bi-arrow-left me-1"></i>Geri
                            </button>
                            <button type="button" class="btn btn-admin-primary">
                                <i class="bi bi-check-circle me-1"></i>Doğrula
                            </button>
                        </div>
                        <div class="resend-section">
                            <p>Kod gelmedi mi?</p>
                            <button type="button" class="btn btn-link">
                                Yeniden gönder <span class="countdown">(30s)</span>
                            </button>
                        </div>
                    </div>
                </form>

                <!-- Footer Links -->
                <div class="login-footer">
                    <p class="copyright">© 2026 De-Kaya Soğutma Sistemleri. Tüm hakları saklıdır.</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Forgot Password Modal -->
    <div class="modal fade" id="forgotPasswordModal" tabindex="-1" aria-labelledby="forgotPasswordModalLabel"
         aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="forgotPasswordModalLabel">
                        <i class="bi bi-key text-primary me-2"></i>
                        Şifre Sıfırlama
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="reset-form">
                        <div class="reset-header">
                            <i class="bi bi-envelope-check text-primary"></i>
                            <h6>E-posta Adresinizi Girin</h6>
                            <p class="text-muted">Şifre sıfırlama bağlantısını e-posta adresinize göndereceğiz</p>
                        </div>
                        <form>
                            <div class="form-group">
                                <div class="input-group">
                                    <span class="input-group-text">
                                        <i class="bi bi-envelope"></i>
                                    </span>
                                    <input type="email" class="form-control" placeholder="mail@de-kaya.com" required>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">İptal</button>
                    <button type="button" class="btn btn-primary">
                        <i class="bi bi-send me-1"></i>Sıfırlama Bağlantısı Gönder
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>
