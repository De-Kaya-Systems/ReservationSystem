@page "/reset-password/{forgotPasswordCode}"
@using DeKayaServer.BlazorApp.Models
@layout ResetPasswordLayout

@inject IAuthService AuthService
@inject NavigationManager NavigationManager
@inject ApiExecutor ApiExecutor
@inject ToastService ToastService
@attribute [AllowAnonymous]

<PageTitle>@PageTitleConstans.AppName  | @PageTitleConstans.ResetPasswordPage</PageTitle>

<div class="login-part">
    <div class="admin-reset-wrapper">
        <div class="admin-reset-container">
            @if (isCheckingToken)
            {
                <!-- Loading Spinner - MainLayout Style -->
                <div class="reset-loading-overlay">
                    <div class="reset-loading-container">
                        <div class="reset-loading-spinner">
                            <div class="reset-spinner-ring"></div>
                            <div class="reset-spinner-ring"></div>
                            <div class="reset-spinner-ring"></div>
                        </div>
                        <div class="reset-loading-content">
                            <div class="logo-circle">
                                <img src="/images/dekaya.png" alt="De-Kaya Logo" class="reset-loading-logo" />
                            </div>
                            <h3 class="reset-loading-text">Güvenlik Kontrolü</h3>
                            <p class="reset-loading-subtitle">Şifre sıfırlama bağlantınız doğrulanıyor...</p>
                        </div>
                    </div>
                </div>
            }
            else if (!isTokenValid)
            {
                <!-- Token Status - Invalid -->
                <div class="admin-reset-form">
                    <div class="reset-header">
                        <div class="admin-brand">
                            <img src="/images/dekaya.png" alt="De-Kaya Logo" />
                            <h1>@PageTitleConstans.AppName</h1>
                        </div>
                    </div>

                    <div class="token-status invalid">
                        <div class="status-icon">
                            <i class="bi bi-shield-x"></i>
                        </div>
                        <div class="status-info">
                            <h6>Geçersiz Bağlantı</h6>
                            <p>@tokenErrorMessage</p>
                        </div>
                    </div>

                    <div class="mt-4 d-flex flex-column gap-3">
                        <a href="@EndpointConstants.LoginPage" class="btn btn-admin-primary w-100">
                            <i class="bi bi-arrow-left me-2"></i>
                            Giriş sayfasına dön
                        </a>
                    </div>
                </div>
            }
            else
            {
                <!-- Left Side - Reset Form -->
                <div class="admin-reset-form">
                    <div class="reset-header">
                        <div class="admin-brand">
                            <img src="/images/dekaya.png" alt="De-Kaya Logo" />
                            <h1>@PageTitleConstans.AppName</h1>
                        </div>
                    </div>

                    <!-- Token Status -->
                    <div class="token-status valid">
                        <div class="status-icon">
                            <i class="bi bi-shield-check"></i>
                        </div>
                        <div class="status-info">
                            <h6>Güvenlik Doğrulandı</h6>
                            <p>Şifre sıfırlama bağlantın geçerli ve güvenli</p>
                        </div>
                    </div>

                    <EditForm Model="@resetPasswordViewModel" OnValidSubmit="@HandleValidSubmit" class="reset-form">
                        <!-- New Password -->
                        <div class="form-group">
                            <label for="newPassword" class="form-label">Yeni Şifre *</label>
                            <div class="input-group">
                                <span class="input-group-text">
                                    <i class="bi bi-lock"></i>
                                </span>
                                <input 
                                    @bind="resetPasswordViewModel.NewPassword"
                                    @bind:event="oninput"
                                    @attributes="NewPasswordTypeAttr"
                                    class="form-control"
                                    id="newPassword"
                                    placeholder="Yeni şifreni gir"
                                    disabled="@isSubmitting" />

                                <button type="button"
                                        class="input-group-text password-toggle"
                                        @onclick="() => showNewPassword = !showNewPassword"
                                        disabled="@isSubmitting">
                                    <i class="bi @(showNewPassword ? "bi-eye-slash" : "bi-eye")"></i>
                                </button>
                            </div>
                        </div>

                        <!-- Password Strength -->
                        <div class="password-strength">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <span class="strength-label">Şifre Gücü: @passwordStrength.Level</span>
                                <span class="strength-text">@passwordStrength.Text</span>
                            </div>
                            <div class="strength-bars">
                                @for (int i = 1; i <= 4; i++)
                                {
                                    var index = i;
                                    <div class="strength-bar @GetStrengthBarClass(index)"></div>
                                }
                            </div>
                        </div>

                        <!-- Password Requirements -->
                        @if (!string.IsNullOrEmpty(resetPasswordViewModel.NewPassword))
                        {
                            <div class="password-requirements">
                                <h6 class="requirements-title">Şifre Gereksinimleri:</h6>
                                <div class="requirements-grid">
                                    <div class="requirement-item @(passwordRequirements.MinLength ? "met" : "")">
                                        <i class="bi bi-x-circle @(passwordRequirements.MinLength ? "met" : "")"></i>
                                        <span>En az 8 karakter</span>
                                    </div>
                                    <div class="requirement-item @(passwordRequirements.HasLowercase ? "met" : "")">
                                        <i class="bi bi-x-circle @(passwordRequirements.HasLowercase ? "text-success" : "text-danger")"></i>
                                        <span>Küçük harf (a-z)</span>
                                    </div>
                                    <div class="requirement-item @(passwordRequirements.HasLowercase ? "met" : "")">
                                        <i class="bi bi-x-circle @(passwordRequirements.HasLowercase ? "text-success" : "text-danger")"></i>
                                        <span>Büyük harf (A-Z)</span>
                                    </div>
                                    <div class="requirement-item @(passwordRequirements.HasUppercase ? "met" : "")">
                                        <i class="bi bi-x-circle @(passwordRequirements.HasUppercase ? "text-success" : "text-danger")"></i>
                                        <span>Rakam (0-9)</span>
                                    </div>
                                    <div class="requirement-item @(passwordRequirements.HasNumber ? "met" : "")">
                                        <i class="bi bi-x-circle @(passwordRequirements.HasNumber ? "text-success" : "text-danger")"></i>
                                        <span>Özel karakter (!#$%^&amp;*)</span>
                                    </div>
                                </div>
                            </div>
                        }

                        <!-- Confirm Password -->
                        <div class="form-group">
                            <label for="confirmPassword" class="form-label">Şifre Tekrarı *</label>
                            <div class="input-group">
                                <span class="input-group-text">
                                    <i class="bi bi-shield-check"></i>
                                </span>
                                <input 
                                    @bind="resetPasswordViewModel.ConfirmPassword"
                                    @bind:event="oninput"
                                    @attributes="ConfirmPasswordTypeAttr"
                                    class="form-control"
                                    id="confirmPassword"
                                    placeholder="Yeni şifreni tekrar gir"
                                    disabled="@isSubmitting" />
                                <button type="button"
                                        class="input-group-text password-toggle"
                                        @onclick="() => showConfirmPassword = !showConfirmPassword"
                                        disabled="@isSubmitting">
                                    <i class="bi @(showConfirmPassword ? "bi-eye-slash" : "bi-eye")"></i>
                                </button>
                            </div>
                            <ValidationMessage For="@(() => resetPasswordViewModel.ConfirmPassword)" class="text-danger small pt-1" />

                            @if (IsPasswordValid())
                            {
                                <div class="password-match">
                                    @if (PasswordsMatch())
                                    {
                                        <div class="match-indicator">
                                            <i class="bi bi-check-circle text-success me-1"></i>
                                            <span class="text-success">Şifreler eşleşiyor</span>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="no-match-indicator">
                                            <i class="bi bi-x-circle text-danger me-1"></i>
                                            <span class="text-danger">Şifreler eşleşmiyor</span>
                                        </div>
                                    }
                                </div>
                            }
                        </div>

                        <!-- Security Options -->
                        <div class="security-options">
                            <h6 class="section-title">Ek Güvenlik Seçenekleri</h6>
                            <div class="options-list">
                                <div class="form-check form-switch">
                                    <input 
                                        class="form-check-input" 
                                        type="checkbox" 
                                        id="logoutAllDevices"
                                        @bind="logoutAllDevices"
                                        disabled="@isSubmitting">
                                    <label class="form-check-label text-start" for="logoutAllDevices">
                                        <strong>Tüm cihazlardan çıkış yap</strong>
                                        <small class="d-block text-muted">
                                            Şifre değişikliğinden sonra diğer cihazlardaki oturumları sonlandır
                                        </small>
                                    </label>
                                </div>
                            </div>
                        </div>

                        <!-- Submit Button -->
                        <button type="submit" class="btn btn-admin-primary w-100" @disabled="!IsFormValid() || isSubmitting">
                            @if (isSubmitting)
                            {
                                <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                                <span>Şifre sıfırlanıyor...</span>
                            }
                            else
                            {
                                <i class="bi bi-shield-check me-2"></i>
                                <span>Şifreyi Sıfırla</span>
                            }
                        </button>

                        <!-- Additional Options -->
                        <div class="additional-options">
                            <div class="divider">
                                <span>veya</span>
                            </div>
                            <div class="option-links">
                                <a href="@EndpointConstants.LoginPage" class="option-link">
                                    <i class="bi bi-arrow-left me-2"></i>
                                    Giriş sayfasına dön
                                </a>
                            </div>
                        </div>
                    </EditForm>
                </div>
            }
        </div>
    </div>
</div>

@code {
    [Parameter]
    public string forgotPasswordCode { get; set; } = null!;

    private ResetPasswordViewModel resetPasswordViewModel = new();
    private bool isSubmitting;
    private bool showNewPassword;
    private bool showConfirmPassword;
    private bool isCheckingToken = true;
    private bool isTokenValid = false;
    private string tokenErrorMessage = "Bu bağlantı geçersiz veya süresi dolmuş. Yeni bir sıfırlama bağlantısı talep edin.";
    private bool logoutAllDevices = true;

    protected override async Task OnInitializedAsync()
    {
        await CheckTokenValidity();
    }

    private async Task CheckTokenValidity()
    {
        isCheckingToken = true;
        StateHasChanged();

        try
        {
            var result = await AuthService.CheckForgotPasswordCodeAsync(forgotPasswordCode);

            if (result.IsSuccessful)
            {
                isTokenValid = result.Data;
            }
            else
            {
                isTokenValid = false;
                tokenErrorMessage = result.ErrorMessages?.FirstOrDefault() ?? tokenErrorMessage;
            }
        }
        catch
        {
            isTokenValid = false;
        }
        finally
        {
            isCheckingToken = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task HandleValidSubmit()
    {
        if (isSubmitting || !IsFormValid())
            return;

        isSubmitting = true;
        StateHasChanged();

        try
        {
            var result = await ApiExecutor.ExecuteAsync(
             () => AuthService.ResetPasswordAsync(forgotPasswordCode, resetPasswordViewModel.NewPassword, logoutAllDevices),
             new ApiPresentationOptions
             {
                 ShowError = true,
                 ShowSuccess = true,
                 ErrorTitle = "Şifre güncelleme"
             });

            if (result.IsSuccessful)
                NavigationManager.NavigateTo(EndpointConstants.LoginPage);
        }
        finally
        {
            isSubmitting = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private PasswordRequirements passwordRequirements => new()
    {
        MinLength = resetPasswordViewModel.NewPassword?.Length >= 8,
        HasLowercase = resetPasswordViewModel.NewPassword?.Any(c => char.IsLower(c)) ?? false,
        HasUppercase = resetPasswordViewModel.NewPassword?.Any(c => char.IsUpper(c)) ?? false,
        HasNumber = resetPasswordViewModel.NewPassword?.Any(c => char.IsDigit(c)) ?? false,
        HasSpecialChar = resetPasswordViewModel.NewPassword?.Any(c => !char.IsLetterOrDigit(c)) ?? false
    };

    private PasswordStrength passwordStrength
    {
        get
        {
            var validCount = new[]
            {
                passwordRequirements.MinLength,
                passwordRequirements.HasLowercase,
                passwordRequirements.HasUppercase,
                passwordRequirements.HasNumber,
                passwordRequirements.HasSpecialChar
            }.Count(x => x);

            return validCount switch
            {
                0 => new PasswordStrength(0, "Zayıf", ""),
                1 or 2 => new PasswordStrength(validCount, "Zayıf", "weak"),
                3 or 4 => new PasswordStrength(validCount, "Orta", "medium"),
                5 => new PasswordStrength(validCount, "Güçlü", "strong"),
                _ => new PasswordStrength(0, "Bilinmiyor", "unknown"),
            };
        }
    }

    private bool IsPasswordValid()
    {
        return passwordRequirements.MinLength &&
               passwordRequirements.HasLowercase &&
               passwordRequirements.HasUppercase &&
               passwordRequirements.HasNumber &&
               passwordRequirements.HasSpecialChar;
    }

    private bool PasswordsMatch()
    {
        return !string.IsNullOrWhiteSpace(resetPasswordViewModel.NewPassword) &&
               !string.IsNullOrWhiteSpace(resetPasswordViewModel.ConfirmPassword) &&
               resetPasswordViewModel.NewPassword == resetPasswordViewModel.ConfirmPassword;
    }

    private bool IsFormValid()
    {
        return IsPasswordValid() && PasswordsMatch();
    }

    private string GetStrengthBarClass(int barIndex)
    {
        if (passwordStrength.Level < barIndex) return "";
        return passwordStrength.Class;
    }

    private IReadOnlyDictionary<string, object> NewPasswordTypeAttr =>
       new Dictionary<string, object> { ["type"] = showNewPassword ? "text" : "password" };

    private IReadOnlyDictionary<string, object> ConfirmPasswordTypeAttr =>
        new Dictionary<string, object> { ["type"] = showConfirmPassword ? "text" : "password" };

    private record PasswordRequirements
    {
        public bool MinLength { get; init; }
        public bool HasLowercase { get; init; }
        public bool HasUppercase { get; init; }
        public bool HasNumber { get; init; }
        public bool HasSpecialChar { get; init; }
    }

    private record PasswordStrength(int Level, string Text, string Class);
}
