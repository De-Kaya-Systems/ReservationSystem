@using DeKayaServer.BlazorApp.Components.Common.UserContext

@inject IAuthService AuthService
@inject NavigationManager Nav
@inherits UserContextComponent

<!-- Profile Dropdown -->
<div class="profile-dropdown">
    <button class="profile-btn" data-bs-toggle="dropdown">
        <img src="https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcRNBRW6kw4PvewS5EGHKY7nNsJiWvrbsVIzZA&s"
             alt="Profile" class="profile-avatar">
        <span class="layout-profile-name">@CurrentUser!.FullName</span>
        <i class="bi bi-chevron-down"></i>
    </button>
    <ul class="dropdown-menu profile-menu">
        <li class="profile-header">
            <div class="profile-info">
                <img src="https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcRNBRW6kw4PvewS5EGHKY7nNsJiWvrbsVIzZA&s"
                     alt="Profile">
                <div>
                    <h6>@CurrentUser.PersonelName</h6>
                    <p>@CurrentUser.Email</p>
                    <span class="role-badge">Süper Admin</span>
                </div>
            </div>
        </li>
        <li>
            <hr class="dropdown-divider">
        </li>
        <li>
            <a class="dropdown-item" href="#">
                <i class="bi bi-person"></i>
                Profilim
            </a>
        </li>
        <li>
            <a class="dropdown-item" href="#">
                <i class="bi bi-gear"></i>
                Hesap Ayarları
            </a>
        </li>
        <li>
            <a class="dropdown-item" href="#">
                <i class="bi bi-bell"></i>
                Bildirim Ayarları
            </a>
        </li>
        <li>
            <a class="dropdown-item" href="#">
                <i class="bi bi-shield-check"></i>
                Güvenlik
            </a>
        </li>
        <li>
            <hr class="dropdown-divider">
        </li>
        <li>
            <a class="dropdown-item" href="#">
                <i class="bi bi-question-circle"></i>
                Yardım & Destek
            </a>
        </li>
        <li>
            <hr class="dropdown-divider">
        </li>
        <li>
            <button type="button" class="dropdown-item text-danger" @onclick="ClickLogOutAsync">
                <i class="bi bi-box-arrow-right"></i>
                Çıkış Yap
            </button>
        </li>
    </ul>
</div>

@code
{
    private async Task ClickLogOutAsync()
    {
        await AuthService.LogOutAsync();
        if (AuthStateProvider is TokenAuthenticationStateProvider tokenProvider)
            await tokenProvider.MarkUserAsLoggedOutAsync();

        Nav.NavigateTo(EndpointConstants.LoginPage, forceLoad: true);
    }
}