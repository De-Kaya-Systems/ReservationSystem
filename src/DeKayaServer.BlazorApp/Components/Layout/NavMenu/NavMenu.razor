@using DeKayaServer.BlazorApp.Components.Common.UserContext

@inherits UserContextComponent

<nav class="sidebar" id="sidebar">
    <div class="sidebar-header">
        <div class="sidebar-brand">
            <img src="/images/dekaya.png" alt="De-Kaya Logo" />
            <span class="brand-text">De-Kaya Systems</span>
        </div>
        <button class="sidebar-toggle" id="sidebarToggle" @onclick="ToggleSidebar">
            <i class="bi bi-list"></i>
        </button>
    </div>

    <div class="sidebar-content">
        <ul class="sidebar-menu">
            @foreach ( var nav in VisibleNavigations )
            {
                var visibleChildren = GetVisibleChildren( nav );
                var hasChildren = nav.Children.Count > 0;
                var isExpanded = ExpandedItems.Contains(nav.Title);

                <li class="menu-item @(hasChildren && isExpanded ? "open" : "")">
                    @if (!hasChildren)
                    {
                        <NavLink class="menu-link" href="@nav.Url" Match="NavLinkMatch.All">
                            @if (!string.IsNullOrWhiteSpace(nav.Icon))
                            {
                                <i class="bi @nav.Icon"></i>
                            }
                            <span class="menu-text">@nav.Title</span>
                        </NavLink>
                    }
                    else
                    {
                        <a href="#" class="menu-link" @onclick="() => ToggleSubMenu(nav.Title)" @onclick:preventDefault>
                            @if (!string.IsNullOrWhiteSpace(nav.Icon))
                            {
                                <i class="bi @nav.Icon"></i>
                            }
                            <span class="menu-text">@nav.Title</span>
                            <i class="bi bi-chevron-right menu-arrow"></i>
                        </a>
                        <ul class="submenu">
                            @foreach ( var child in visibleChildren )
                            {
                                <li>
                                    <NavLink href="@child.Url">@child.Title</NavLink>
                                </li>
                            }
                        </ul>
                    }
                </li>
            }
        </ul>
    </div>

    <div class="sidebar-footer">
        <div class="user-info">
            <div class="user-avatar">
                <img src="https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcRNBRW6kw4PvewS5EGHKY7nNsJiWvrbsVIzZA&s"
                     alt="Admin">
            </div>
            <div class="user-details">
                <span class="user-name">@CurrentUser.PersonelName</span>
                <small>@CurrentUser.Email</small>
                <span class="user-role">@CurrentUser.Role</span>
            </div>
        </div>
    </div>
</nav>

@code 
{
    private IReadOnlyList<NavigationItem> Navigations => NavigationData.Items;

    private IReadOnlyList<NavigationItem> VisibleNavigations 
        => Navigations
            .Where( IsNavVisibleConsideringChildren )
            .ToList();

    private HashSet<string> ExpandedItems = new();

    private bool IsSideBarOpen = true;

    private void ToggleSidebar()
    {
        IsSideBarOpen = !IsSideBarOpen;
    }

    private void ToggleSubMenu(string key)
    {
        if (!ExpandedItems.Add(key))
            ExpandedItems.Remove(key);
    }

    private bool IsNavVisibleConsideringChildren( NavigationItem nav )
    {
        //parent permission varsa ve user'da varsa göster
        //EN: If the parent has a permission and the user has that permission, show it
        if ( CurrentUser.HasPermission( nav.Permission ?? string.Empty ) )
        {
            return true;
        }

        // parent yetkisi yoksa child'lardan en az biri görünüyorsa parent'ı göster
        //EN: If the parent doesn't have a permission, but at least one child is visible, show the parent
        return nav.Children.Any( child => CurrentUser.HasPermission( child.Permission ?? string.Empty ) );
    }

    private List<NavigationItem> GetVisibleChildren( NavigationItem nav )
        => nav.Children
            .Where( c => CurrentUser.HasPermission( c.Permission ?? string.Empty ) )
            .ToList();
}