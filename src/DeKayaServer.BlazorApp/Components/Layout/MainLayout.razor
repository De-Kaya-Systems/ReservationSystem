@using Microsoft.AspNetCore.Components.Authorization
@inject AuthenticationStateProvider AuthStateProvider
@using DeKayaServer.BlazorApp.Components.Layout.NavMenu
@using DeKayaServer.BlazorApp.Components.Pages.Header
@using DeKayaServer.BlazorApp.Constans
@using DeKayaServer.BlazorApp.Interfaces
@inject IAccessTokenStoreService TokenStore
@inject NavigationManager Nav

@inherits LayoutComponentBase

<PageTitle>De-Kaya Systems</PageTitle>

@if (!ready)
{
    <div class="loading-overlay">
        <div class="loading-container">
            <div class="loading-spinner">
                <div class="spinner-ring"></div>
                <div class="spinner-ring"></div>
                <div class="spinner-ring"></div>
            </div>
            <div class="loading-content">
                <div class="logo-circle">
                    <img src="/images/dekaya.png" alt="De-Kaya Logo" class="loading-logo" />
                </div>
                <h3 class="loading-text">De-Kaya Systems</h3>
                <p class="loading-subtitle">Yükleniyor...</p>
            </div>
        </div>
    </div>
}
else
{
    <div class="page">
        <div class="sidebar">
            <NavMenu />
        </div>

        <div class="main-wrapper">
            <!-- Top Navbar -->
            <HeaderComponent />

            <!-- Main Content -->
            <main class="main-content">
                <div class="content-wrapper">
                    <!-- Dashboard Content -->
                    <div class="content-area">
                        @Body
                    </div>
                </div>
            </main>
        </div>
    </div>
}

@code {
    private bool ready;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();

        if (!authState.User.Identity?.IsAuthenticated ?? false)
        {
            var returnUrl = Uri.EscapeDataString(Nav.ToBaseRelativePath(Nav.Uri));
            Nav.NavigateTo($"{EndpointConstans.LoginPage}{returnUrl}", forceLoad: true);
            return;
        }
        ready = true;
    }
}