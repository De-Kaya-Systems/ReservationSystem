@using DeKayaServer.BlazorApp.Components.Layout.Breadcrumb
@using DeKayaServer.BlazorApp.Components.Layout.NavMenu
@inherits LayoutComponentBase

<PageTitle>De-Kaya Systems</PageTitle>

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <div class="main-wrapper">
        <!-- Top Navbar -->
        <header class="navbar-custom">
            <div class="navbar-content">
                <!-- Left Side - Breadcrumb -->
                <div class="navbar-left">
                    <button class="mobile-sidebar-toggle d-lg-none">
                        <i class="bi bi-list"></i>
                    </button>
                    <nav aria-label="breadcrumb">
                        <Breadcrumb />
                    </nav>
                </div>

                <!-- Right Side - Profile & Notifications -->
                <div class="navbar-right">
                    <!-- Notifications -->
                    <div class="notification-dropdown">
                        <button class="notification-btn" data-bs-toggle="dropdown">
                            <i class="bi bi-bell"></i>
                            <span class="notification-badge">3</span>
                        </button>
                        <ul class="dropdown-menu notification-menu">
                            <li class="notification-header">
                                <h6>Bildirimler</h6>
                                <span class="badge bg-primary">3 Yeni</span>
                            </li>
                            <li>
                                <hr class="dropdown-divider">
                            </li>
                            <li class="notification-item">
                                <div class="notification-icon bg-success">
                                    <i class="bi bi-check-circle"></i>
                                </div>
                                <div class="notification-content">
                                    <h6>Yeni Rezervasyon</h6>
                                    <p>BMW 320i için yeni rezervasyon alındı</p>
                                    <small>5 dakika önce</small>
                                </div>
                            </li>
                            <li class="notification-item">
                                <div class="notification-icon bg-warning">
                                    <i class="bi bi-exclamation-triangle"></i>
                                </div>
                                <div class="notification-content">
                                    <h6>Bakım Hatırlatması</h6>
                                    <p>Mercedes C180'in bakım zamanı geldi</p>
                                    <small>2 saat önce</small>
                                </div>
                            </li>
                            <li class="notification-item">
                                <div class="notification-icon bg-info">
                                    <i class="bi bi-info-circle"></i>
                                </div>
                                <div class="notification-content">
                                    <h6>Sistem Güncellemesi</h6>
                                    <p>Yeni özellikler eklendi</p>
                                    <small>1 gün önce</small>
                                </div>
                            </li>
                            <li>
                                <hr class="dropdown-divider">
                            </li>
                            <li class="notification-footer">
                                <a href="#">Tüm Bildirimleri Gör</a>
                            </li>
                        </ul>
                    </div>

                    <!-- Profile Dropdown -->
                    <div class="profile-dropdown">
                        <button class="profile-btn" data-bs-toggle="dropdown">
                            <img src="https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcRNBRW6kw4PvewS5EGHKY7nNsJiWvrbsVIzZA&s"
                                alt="Profile" class="profile-avatar">
                            <span class="layout-profile-name">Admin User</span>
                            <i class="bi bi-chevron-down"></i>
                        </button>
                        <ul class="dropdown-menu profile-menu">
                            <li class="profile-header">
                                <div class="profile-info">
                                    <img src="https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcRNBRW6kw4PvewS5EGHKY7nNsJiWvrbsVIzZA&s"
                                        alt="Profile">
                                    <div>
                                        <h6>Admin User</h6>
                                        <p>admin@rentcar.com</p>
                                        <span class="role-badge">Süper Admin</span>
                                    </div>
                                </div>
                            </li>
                            <li>
                                <hr class="dropdown-divider">
                            </li>
                            <li>
                                <a class="dropdown-item" href="#">
                                    <i class="bi bi-person"></i>
                                    Profilim
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item" href="#">
                                    <i class="bi bi-gear"></i>
                                    Hesap Ayarları
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item" href="#">
                                    <i class="bi bi-bell"></i>
                                    Bildirim Ayarları
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item" href="#">
                                    <i class="bi bi-shield-check"></i>
                                    Güvenlik
                                </a>
                            </li>
                            <li>
                                <hr class="dropdown-divider">
                            </li>
                            <li>
                                <a class="dropdown-item" href="#">
                                    <i class="bi bi-question-circle"></i>
                                    Yardım & Destek
                                </a>
                            </li>
                            <li>
                                <hr class="dropdown-divider">
                            </li>
                            <li>
                                <a class="dropdown-item text-danger" href="#">
                                    <i class="bi bi-box-arrow-right"></i>
                                    Çıkış Yap
                                </a>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
        </header>

        <!-- Main Content -->
        <main class="main-content">
            <div class="content-wrapper">
                <!-- Dashboard Content -->
                <div class="content-area">
                    @Body
                </div>
            </div>
        </main>
    </div>
</div>
